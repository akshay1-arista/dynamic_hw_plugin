# Optional overrides for the dynamic-hw-topology systemd services.
# Copy this to /etc/default/dynamic-hw-topology and edit as needed.

# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=5401
# FRONTEND_HOST=0.0.0.0
# FRONTEND_PORT=5400
# PUBLIC_HOST=your-server-hostname-or-ip
# CORS_ALLOWED_ORIGINS=http://your-server-hostname-or-ip:5400
# REFERENCE_CONFIG_ROOT=/absolute/path/to/reference_topologies
# LAB_NAVIGATOR_BASE_URL=https://lab-navigator.velo.maa.aristanetworks.com
# LN_PROD_API_KEY=your-api-key
