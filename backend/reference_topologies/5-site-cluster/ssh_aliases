#!/bin/bash

# Last used bastion host IP (auto-updated)
LAST_BH_IP=""

# Function to set up aliases with bastion host IP
setup_aliases() {
    local bh_ip="$1"

    # If no argument provided, use last saved IP
    if [ -z "$bh_ip" ]; then
        if [ -n "$LAST_BH_IP" ]; then
            bh_ip="$LAST_BH_IP"
            echo "Using saved bastion host: $bh_ip"
        else
            echo "Usage: source ssh_aliases <bastion_host_ip>"
            echo "Example: source ssh_aliases 172.29.236.90"
            return 1
        fi
    else
        # Save the new IP to the file for next time
        SCRIPT_PATH="${BASH_SOURCE[0]}"
        if [[ "$OSTYPE" == "darwin"* ]]; then
            # macOS
            sed -i '' "s/^LAST_BH_IP=.*/LAST_BH_IP=\"$bh_ip\"/" "$SCRIPT_PATH"
        else
            # Linux
            sed -i "s/^LAST_BH_IP=.*/LAST_BH_IP=\"$bh_ip\"/" "$SCRIPT_PATH"
        fi
        echo "Setting bastion host to: $bh_ip (saved for future use)"
    fi

    export bh=$bh_ip

    # Bastion host
    alias bh='sshpass -p velocloud ssh root@$bh -o StrictHostKeyChecking=No -o UserKnownHostsFile=/dev/null'

    # Branch 1 Edges
    alias b1e1='sshpass -p velocloud ssh root@$bh -p 1001 -o StrictHostKeyChecking=No -o UserKnownHostsFile=/dev/null'
    alias b1e2='sshpass -p velocloud ssh root@$bh -p 1006 -o StrictHostKeyChecking=No -o UserKnownHostsFile=/dev/null'
